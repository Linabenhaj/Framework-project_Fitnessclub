@model FitnessClub.Web.Models.RegisterModel
@{
    ViewData["Title"] = "Registreren";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">
                        <i class="bi bi-person-plus"></i> @ViewData["Title"]
                    </h3>
                </div>
                <div class="card-body">
                    <form asp-action="Register" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Voornaam" class="form-label"></label>
                                <input asp-for="Voornaam" class="form-control" />
                                <span asp-validation-for="Voornaam" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Achternaam" class="form-label"></label>
                                <input asp-for="Achternaam" class="form-control" />
                                <span asp-validation-for="Achternaam" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Telefoonnummer" class="form-label"></label>
                            <input asp-for="Telefoonnummer" class="form-control" />
                            <span asp-validation-for="Telefoonnummer" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Wachtwoord" class="form-label"></label>
                            <input asp-for="Wachtwoord" class="form-control" type="password" />
                            <span asp-validation-for="Wachtwoord" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="BevestigWachtwoord" class="form-label"></label>
                            <input asp-for="BevestigWachtwoord" class="form-control" type="password" />
                            <span asp-validation-for="BevestigWachtwoord" class="text-danger"></span>
                        </div>

                        <input type="hidden" asp-for="SubscriptionTypeId" value="2" />

                        <div class="form-check mb-3">
                            <input asp-for="AccepteerVoorwaarden" class="form-check-input" />
                            <label asp-for="AccepteerVoorwaarden" class="form-check-label">
                                Ik ga akkoord met de voorwaarden
                            </label>
                            <span asp-validation-for="AccepteerVoorwaarden" class="text-danger d-block"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-person-check"></i> Registreren
                            </button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center">
                    <small class="text-muted">
                        Al een account?
                        <a asp-action="Login" asp-controller="Account">Inloggen</a>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}