@using Microsoft.AspNetCore.Mvc.Localization
@using FitnessClub.Web.Translations
@inject IHtmlLocalizer<SharedResource> L
@model FitnessClub.Models.Models.Les

@{
    ViewData["Title"] = L["Details"].Value;
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="bi bi-calendar-event"></i> @Model.Naam</h4>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">@L["Description"]</dt>
                    <dd class="col-sm-9">@Model.Beschrijving</dd>

                    <dt class="col-sm-3">@L["Trainer"]</dt>
                    <dd class="col-sm-9">@Model.Trainer</dd>

                    <dt class="col-sm-3">@L["Location"]</dt>
                    <dd class="col-sm-9">@Model.Locatie</dd>

                    <dt class="col-sm-3">@L["StartTime"]</dt>
                    <dd class="col-sm-9">@Model.StartTijd.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-3">@L["EndTime"]</dt>
                    <dd class="col-sm-9">@Model.EindTijd.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-3">Max</dt>
                    <dd class="col-sm-9">@Model.MaxDeelnemers</dd>
                </dl>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> @L["Back"]
                </a>
                @if (User.Identity!.IsAuthenticated && !User.IsInRole("Admin") && Model.StartTijd > DateTime.Now)
                {
                    <form asp-action="SchrijfIn" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-calendar-plus"></i> @L["Enroll"]
                        </button>
                    </form>
                }
                @if (User.IsInRole("Admin"))
                {
                    <div>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                            <i class="bi bi-pencil"></i> @L["Edit"]
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                            <i class="bi bi-trash"></i> @L["Delete"]
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
