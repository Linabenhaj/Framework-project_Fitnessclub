@using Microsoft.AspNetCore.Mvc.Localization
@using FitnessClub.Web.Resources
@inject IHtmlLocalizer<SharedResource> L
@model FitnessClub.Models.Models.Les

@{
    ViewData["Title"] = L["Add"].Value + " " + L["Lessons"].Value;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="bi bi-calendar-plus"></i> @L["Add"] @L["Lessons"]</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Naam" class="form-label fw-bold">@L["Name"]</label>
                        <input asp-for="Naam" class="form-control" />
                        <span asp-validation-for="Naam" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Beschrijving" class="form-label fw-bold">@L["Description"]</label>
                        <textarea asp-for="Beschrijving" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="StartTijd" class="form-label fw-bold">@L["StartTime"]</label>
                            <input asp-for="StartTijd" class="form-control" type="datetime-local" />
                            <span asp-validation-for="StartTijd" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EindTijd" class="form-label fw-bold">@L["EndTime"]</label>
                            <input asp-for="EindTijd" class="form-control" type="datetime-local" />
                            <span asp-validation-for="EindTijd" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MaxDeelnemers" class="form-label fw-bold">Max deelnemers</label>
                        <input asp-for="MaxDeelnemers" class="form-control" type="number" min="1" max="100" />
                        <span asp-validation-for="MaxDeelnemers" class="text-danger"></span>
                    </div>

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> De <strong>trainer</strong> wordt later toegevoegd
                        wanneer een geregistreerde trainer zichzelf aangeeft voor deze les.
                    </div>

                    @* Plain HTML hidden inputs — asp-for zou de model-waarde overschrijven *@
                    <input type="hidden" name="Trainer" value="" />
                    <input type="hidden" name="IsActief" value="true" />

                    <div class="mb-3">
                        <label asp-for="Locatie" class="form-label fw-bold">@L["Location"]</label>
                        <input asp-for="Locatie" class="form-control" />
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> @L["Back"]
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> @L["Add"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
