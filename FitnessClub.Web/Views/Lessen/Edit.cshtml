@using Microsoft.AspNetCore.Mvc.Localization
@using FitnessClub.Web.Translations
@inject IHtmlLocalizer<SharedResource> L
@model FitnessClub.Models.Models.Les

@{
    ViewData["Title"] = L["Edit"].Value;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h4 class="mb-0"><i class="bi bi-pencil-square"></i> @L["Edit"] @L["Lessons"]</h4>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="AangemaaktOp" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Naam" class="form-label fw-bold">@L["Name"]</label>
                        <input asp-for="Naam" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Beschrijving" class="form-label fw-bold">@L["Description"]</label>
                        <textarea asp-for="Beschrijving" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="StartTijd" class="form-label fw-bold">@L["StartTime"]</label>
                            <input asp-for="StartTijd" class="form-control" type="datetime-local" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EindTijd" class="form-label fw-bold">@L["EndTime"]</label>
                            <input asp-for="EindTijd" class="form-control" type="datetime-local" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MaxDeelnemers" class="form-label fw-bold">Max deelnemers</label>
                        <input asp-for="MaxDeelnemers" class="form-control" type="number" min="1" max="100" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">@L["Trainer"] (toegewezen)</label>
                        <input value="@(string.IsNullOrEmpty(Model.Trainer) ? "— Nog niet toegewezen —" : Model.Trainer)"
                               class="form-control" disabled />
                        <small class="text-muted">Wordt automatisch ingevuld wanneer een trainer zich aangeeft.</small>
                    </div>

                    <input type="hidden" asp-for="Trainer" />

                    <div class="mb-3">
                        <label asp-for="Locatie" class="form-label fw-bold">@L["Location"]</label>
                        <input asp-for="Locatie" class="form-control" />
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="IsActief" class="form-check-input" />
                        <label asp-for="IsActief" class="form-check-label">@L["Available"]</label>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> @L["Back"]
                        </a>
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-check-circle"></i> @L["Save"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
