@using Microsoft.AspNetCore.Mvc.Localization
@using FitnessClub.Web.Translations
@inject IHtmlLocalizer<SharedResource> L
@model FitnessClub.Web.Models.PaginatedList<FitnessClub.Models.Models.Les>

@{
    ViewData["Title"] = L["Lessons"].Value;
}

<div class="container mt-4">
    <h1 class="mb-4"><i class="bi bi-calendar3"></i> @ViewData["Title"]</h1>

    <!-- AJAX laadindicator  -->
    <div id="loading" class="text-center mb-3" style="display:none;">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2">@L["Search"]...</p>
    </div>

    <!-- Filter & Zoek-kaart -->
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-funnel"></i> Filter &amp; @L["Search"]</h5>
        </div>
        <div class="card-body">
            @* Declaratieve AJAX-form via data-ajax attributen (Unobtrusive Ajax) *@
            <form id="filterForm"
                  data-ajax="true"
                  data-ajax-method="GET"
                  data-ajax-url="@Url.Action("LoadLessenPartial", "Lessen")"
                  data-ajax-mode="replace"
                  data-ajax-update="#lessenContainer"
                  data-ajax-loading="#loading"
                  data-ajax-success="onAjaxSuccess">

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">@L["Search"]</label>
                        <input type="text" id="searchInput" name="searchString" class="form-control"
                               value="@ViewData["CurrentFilter"]"
                               placeholder="@L["Search"]..." />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">@L["Trainer"]</label>
                        <select id="trainerFilter" name="filterTrainer" class="form-select">
                            <option value="all">@L["Trainer"]</option>
                            @{
                                var trainers = ViewData["Trainers"] as List<string> ?? new List<string>();
                                var currentTrainer = ViewData["CurrentTrainerFilter"] as string;
                            }
                            @foreach (var trainer in trainers)
                            {
                                <option value="@trainer" selected="@(trainer == currentTrainer)">@trainer</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Sorteer</label>
                        <select id="sortOrder" name="sortOrder" class="form-select">
                            <option value="">@L["StartTime"]</option>
                            <option value="start_desc" selected="@(ViewData["CurrentSort"]?.ToString() == "start_desc")">@L["StartTime"] (desc)</option>
                            <option value="naam" selected="@(ViewData["CurrentSort"]?.ToString() == "naam")">@L["Name"] A-Z</option>
                            <option value="naam_desc" selected="@(ViewData["CurrentSort"]?.ToString() == "naam_desc")">@L["Name"] Z-A</option>
                            <option value="Trainer" selected="@(ViewData["CurrentSort"]?.ToString() == "Trainer")">@L["Trainer"] A-Z</option>
                            <option value="trainer_desc" selected="@(ViewData["CurrentSort"]?.ToString() == "trainer_desc")">@L["Trainer"] Z-A</option>
                        </select>
                    </div>

                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search"></i> @L["Search"]
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Container die door AJAX vervangen wordt -->
    <div id="lessenContainer">
        @await Html.PartialAsync("_lessentable", Model)
    </div>

    <div class="mt-4 text-end">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> @L["Add"] @L["Lessons"]
            </a>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Callback voor wanneer Unobtrusive Ajax een succesvolle response verwerkt
        function onAjaxSuccess() {
            // Eventueel: notificaties of UI-state updates
            console.log("Lessen-tabel vernieuwd via Unobtrusive Ajax.");
        }

        // Real-time zoeken (auto-submit met debounce)
        $(function () {
            let searchTimeout;
            $('#searchInput, #trainerFilter, #sortOrder').on('input change', function () {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(function () {
                    $('#filterForm').submit();
                }, 400);
            });
        });
    </script>
}
