@using FitnessClub.Web.Controllers
@model List<GebruikerViewItem>

@{
    ViewData["Title"] = "Gebruikers";
}

<h1 class="mb-4"><i class="bi bi-people"></i> Gebruikers</h1>

<div class="row mb-3">
    <div class="col-md-8">
        <form method="get" class="input-group">
            <input type="text" class="form-control" name="searchString"
                   value="@ViewData["CurrentFilter"]" placeholder="Zoek op naam of email..." />
            <button class="btn btn-primary" type="submit">
                <i class="bi bi-search"></i> Zoeken
            </button>
        </form>
    </div>
    <div class="col-md-4 text-end">
        <span class="badge bg-secondary">@Model.Count gebruikers</span>
    </div>
</div>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Naam</th>
                    <th>Email</th>
                    <th>Telefoon</th>
                    <th>Rol</th>
                    <th>Abonnement</th>
                    <th>Acties</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var g = item.Gebruiker;
                    <tr>
                        <td>@g.Voornaam @g.Achternaam</td>
                        <td>@g.Email</td>
                        <td>@(string.IsNullOrEmpty(g.PhoneNumber) ? "—" : g.PhoneNumber)</td>
                        <td><span class="badge bg-info">@item.Rol</span></td>
                        <td>@(g.Abonnement?.Naam ?? "—")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@g.Id" class="btn btn-info btn-sm" title="Details">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@g.Id" class="btn btn-warning btn-sm" title="Bewerken">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@g.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Weet je zeker dat je deze gebruiker definitief wil verwijderen?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger btn-sm" title="Verwijderen">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> Geen gebruikers gevonden.
    </div>
}
