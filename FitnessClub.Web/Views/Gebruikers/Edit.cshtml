@using Microsoft.AspNetCore.Mvc.Localization
@using FitnessClub.Web.Resources
@inject IHtmlLocalizer<SharedResource> L
@model FitnessClub.Models.Models.Gebruiker

@{ ViewData["Title"] = L["Edit"].Value; }

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h4 class="mb-0"><i class="bi bi-pencil-square"></i> @L["Edit"] @L["Users"]</h4>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">@L["FirstName"]</label>
                            <input name="Voornaam" value="@Model.Voornaam" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">@L["LastName"]</label>
                            <input name="Achternaam" value="@Model.Achternaam" class="form-control" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">@L["Email"]</label>
                        <input name="Email" value="@Model.Email" class="form-control" type="email" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">@L["Phone"]</label>
                        <input name="Telefoon" value="@Model.PhoneNumber" class="form-control" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">@L["Role"]</label>
                            <select name="Rol" asp-items="ViewBag.RollenList" class="form-select"></select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">@L["Subscription"]</label>
                            <select name="AbonnementId" asp-items="ViewBag.AbonnementenList" class="form-select">
                                <option value="">—</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> @L["Back"]
                        </a>
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-check-circle"></i> @L["Save"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
