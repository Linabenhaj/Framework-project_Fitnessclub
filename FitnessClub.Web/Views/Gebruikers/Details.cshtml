@using Microsoft.AspNetCore.Mvc.Localization
@using FitnessClub.Web.Resources
@inject IHtmlLocalizer<SharedResource> L
@model FitnessClub.Models.Models.Gebruiker

@{ ViewData["Title"] = L["Details"].Value; }

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="bi bi-person-circle"></i> @Model.Voornaam @Model.Achternaam</h4>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">@L["Email"]</dt>
                    <dd class="col-sm-9">@Model.Email</dd>

                    <dt class="col-sm-3">@L["Phone"]</dt>
                    <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "—" : Model.PhoneNumber)</dd>

                    <dt class="col-sm-3">@L["Subscription"]</dt>
                    <dd class="col-sm-9">
                        @if (Model.Abonnement != null)
                        {
                            <span class="badge bg-info">@Model.Abonnement.Naam</span>
                            <small>(€ @Model.Abonnement.Prijs.ToString("F2"))</small>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </dd>

                    <dt class="col-sm-3">@L["Role"]</dt>
                    <dd class="col-sm-9">
                        @if (ViewBag.Rollen != null && ((IEnumerable<string>)ViewBag.Rollen).Any())
                        {
                            foreach (var rol in (IEnumerable<string>)ViewBag.Rollen)
                            {
                                <span class="badge bg-secondary">@rol</span>
                            }
                        }
                        else { <span class="text-muted">—</span> }
                    </dd>

                    <dt class="col-sm-3">@L["MemberSince"]</dt>
                    <dd class="col-sm-9">@Model.AangemaaktOp.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> @L["Back"]
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil"></i> @L["Edit"]
                </a>
            </div>
        </div>
    </div>
</div>
