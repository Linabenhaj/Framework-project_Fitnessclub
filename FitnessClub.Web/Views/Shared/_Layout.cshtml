@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.Localization
@using FitnessClub.Models.Models
@using FitnessClub.Web.Resources
@inject UserManager<Gebruiker> UserManager
@inject SignInManager<Gebruiker> SignInManager
@inject IHtmlLocalizer<SharedResource> L

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Fitness Club</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-3">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-heart-pulse-fill"></i> Fitness Club
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Lessen" asp-action="Index">@L["Lessons"]</a>
                        </li>
                        @* Inschrijvingen-link niet voor Trainer alleen Admin en Lid *@
                        @if (!User.IsInRole("Trainer"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Inschrijvingen" asp-action="Index">
                                    @(User.IsInRole("Admin") ? L["Enrollments"] : L["MyEnrollments"])
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Abonnementen" asp-action="Index">@L["Subscriptions"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Gebruikers" asp-action="Index">@L["Users"]</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Account" asp-action="Profile">@L["MyProfile"]</a>
                            </li>
                        }
                    }
                </ul>

                <ul class="navbar-nav ms-auto">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle text-light" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-translate"></i> @L["Language"]
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-controller="Home" asp-action="SetLanguage"
                                   asp-route-culture="nl" asp-route-returnUrl="@Context.Request.Path">🇳🇱 Nederlands</a></li>
                            <li><a class="dropdown-item" asp-controller="Home" asp-action="SetLanguage"
                                   asp-route-culture="en" asp-route-returnUrl="@Context.Request.Path">🇬🇧 English</a></li>
                            <li><a class="dropdown-item" asp-controller="Home" asp-action="SetLanguage"
                                   asp-route-culture="fr" asp-route-returnUrl="@Context.Request.Path">🇫🇷 Français</a></li>
                        </ul>
                    </li>

                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item">
                            <span class="nav-link text-light">
                                <i class="bi bi-person-circle"></i> @User.Identity?.Name
                            </span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-flex">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="nav-link btn btn-link text-light">@L["Logout"]</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Account" asp-action="Register">@L["Register"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Account" asp-action="Login">@L["Login"]</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="border-top footer text-muted mt-5">
        <div class="container py-3">
            &copy; @DateTime.Now.Year - Fitness Club &middot; Lina Benhaj
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @* Unobtrusive Ajax — voor declaratieve AJAX via data-ajax-* attributen (school-stijl) *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-ajax-unobtrusive/3.2.6/jquery.unobtrusive-ajax.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
