@model FitnessClub.Web.Models.PaginatedList<FitnessClub.Models.Models.Taal>

@{
    ViewData["Title"] = "Talen";
}

<div class="container mt-4">
    <h1 class="mb-4"><i class="bi bi-translate"></i> @ViewData["Title"]</h1>

    <div class="row mb-4">
        <div class="col-md-6 text-end">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-success">
                    <i class="bi bi-plus-circle"></i> Nieuwe Taal
                </a>
            }
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Naam</th>
                        <th>Cultuur Code</th>
                        <th>Actief</th>
                        <th>Acties</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var taal in Model)
                    {
                        <tr>
                            <td>@taal.Naam</td>
                            <td>@taal.CultuurCode</td>
                            <td>
                                <span class="badge @(taal.IsActief ? "bg-success" : "bg-secondary")">
                                    @(taal.IsActief ? "Actief" : "Inactief")
                                </span>
                            </td>
                            <td>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@taal.Id" class="btn btn-warning btn-sm">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@taal.Id" class="btn btn-danger btn-sm">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Geen talen gevonden.
        </div>
    }
</div>