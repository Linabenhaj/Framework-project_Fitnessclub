@using Microsoft.AspNetCore.Identity
@using FitnessClub.Models.Models
@inject SignInManager<Gebruiker> SignInManager
@inject UserManager<Gebruiker> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link text-light" asp-controller="Account" asp-action="Profile">
                <i class="bi bi-person-circle"></i> @User.Identity?.Name
            </a>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()  
                <button type="submit" class="nav-link btn btn-link text-light">
                    <i class="bi bi-box-arrow-right"></i> Uitloggen
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-light" asp-controller="Account" asp-action="Register">
                <i class="bi bi-person-plus"></i> Registreren
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-light" asp-controller="Account" asp-action="Login">
                <i class="bi bi-box-arrow-in-right"></i> Inloggen
            </a>
        </li>
    }
</ul>