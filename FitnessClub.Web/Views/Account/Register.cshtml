@using Microsoft.AspNetCore.Mvc.Localization
@using FitnessClub.Web.Translations
@inject IHtmlLocalizer<SharedResource> L
@model FitnessClub.Web.Models.RegisterModel

@{
    ViewData["Title"] = L["Register"].Value;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h3 class="mb-0"><i class="bi bi-person-plus"></i> @L["CreateAccount"]</h3>
            </div>
            <div class="card-body">
                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Voornaam" class="form-label">@L["FirstName"]</label>
                            <input asp-for="Voornaam" class="form-control" />
                            <span asp-validation-for="Voornaam" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Achternaam" class="form-label">@L["LastName"]</label>
                            <input asp-for="Achternaam" class="form-control" />
                            <span asp-validation-for="Achternaam" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">@L["Email"]</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Telefoonnummer" class="form-label">@L["Phone"]</label>
                        <input asp-for="Telefoonnummer" class="form-control" />
                        <span asp-validation-for="Telefoonnummer" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Wachtwoord" class="form-label">@L["Password"]</label>
                        <input asp-for="Wachtwoord" class="form-control" type="password" />
                        <span asp-validation-for="Wachtwoord" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="BevestigWachtwoord" class="form-label">@L["ConfirmPassword"]</label>
                        <input asp-for="BevestigWachtwoord" class="form-control" type="password" />
                        <span asp-validation-for="BevestigWachtwoord" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AbonnementId" class="form-label">@L["Subscription"]</label>
                        <select asp-for="AbonnementId" asp-items="ViewBag.AbonnementenList" class="form-select">
                            <option value="">—</option>
                        </select>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="AccepteerVoorwaarden" class="form-check-input" />
                        <label asp-for="AccepteerVoorwaarden" class="form-check-label">
                            @L["Register"]
                        </label>
                        <span asp-validation-for="AccepteerVoorwaarden" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-person-plus"></i> @L["CreateAccount"]
                        </button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> @L["Back"]
                        </a>
                    </div>
                </form>
            </div>
            <div class="card-footer text-center">
                <small class="text-muted">
                    <a asp-action="Login">@L["Login"]</a>
                </small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
