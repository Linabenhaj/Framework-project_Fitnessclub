@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.Localization
@using FitnessClub.Models.Models
@using FitnessClub.Web.Resources
@inject SignInManager<Gebruiker> SignInManager
@inject UserManager<Gebruiker> UserManager
@inject IHtmlLocalizer<SharedResource> L

@{
    ViewData["Title"] = L["Welcome"].Value;
}

@if (!SignInManager.IsSignedIn(User))
{
    <div class="text-center py-5">
        <h1 class="display-3 fw-bold mb-3">
            <i class="bi bi-heart-pulse-fill text-success"></i> Fitness Club Pro
        </h1>
        <p class="lead text-muted mb-4">@L["WelcomeSubtitle"]</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a class="btn btn-success btn-lg px-4" asp-controller="Account" asp-action="Login">
                <i class="bi bi-box-arrow-in-right"></i> @L["Login"]
            </a>
            <a class="btn btn-outline-primary btn-lg px-4" asp-controller="Account" asp-action="Register">
                <i class="bi bi-person-plus"></i> @L["CreateAccount"]
            </a>
        </div>
    </div>

    <div class="row mt-5 g-4">
        <div class="col-md-4">
            <div class="card h-100 text-center p-4 border-0">
                <div class="mb-3"><i class="bi bi-calendar-event text-primary" style="font-size:3rem;"></i></div>
                <h5 class="fw-bold">@L["OurLessons"]</h5>
                <p class="text-muted small mb-0">@L["OurLessonsDesc"]</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 text-center p-4 border-0">
                <div class="mb-3"><i class="bi bi-credit-card text-success" style="font-size:3rem;"></i></div>
                <h5 class="fw-bold">@L["FlexibleSubs"]</h5>
                <p class="text-muted small mb-0">@L["FlexibleSubsDesc"]</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 text-center p-4 border-0">
                <div class="mb-3"><i class="bi bi-people text-warning" style="font-size:3rem;"></i></div>
                <h5 class="fw-bold">@L["PersonalGuidance"]</h5>
                <p class="text-muted small mb-0">@L["PersonalGuidanceDesc"]</p>
            </div>
        </div>
    </div>

    <div class="row justify-content-center mt-5">
        <div class="col-md-8">
            <div class="card bg-light border-0">
                <div class="card-body">
                    <h6 class="fw-bold mb-2"><i class="bi bi-info-circle text-primary"></i> @L["DemoAccounts"]</h6>
                    <ul class="mb-0 small">
                        <li><strong>@L["Admin"]:</strong> admin@fitnessclub.be / Admin123!</li>
                        <li><strong>@L["Login"]:</strong> user@fitnessclub.be / User123!</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center py-4">
        <h1 class="display-5 fw-bold">@L["WelcomeBack"], @User.Identity?.Name 👋</h1>
    </div>

    <div class="row g-4 mt-3">
        @if (User.IsInRole("Admin"))
        {
            <div class="col-md-4">
                <a asp-controller="Lessen" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 text-center p-4 border-0">
                        <i class="bi bi-calendar-event text-primary mb-2" style="font-size:2.5rem;"></i>
                        <h5 class="fw-bold">@L["Lessons"]</h5>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Abonnementen" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 text-center p-4 border-0">
                        <i class="bi bi-credit-card text-success mb-2" style="font-size:2.5rem;"></i>
                        <h5 class="fw-bold">@L["Subscriptions"]</h5>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Gebruikers" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 text-center p-4 border-0">
                        <i class="bi bi-people text-warning mb-2" style="font-size:2.5rem;"></i>
                        <h5 class="fw-bold">@L["Users"]</h5>
                    </div>
                </a>
            </div>
        }
        else
        {
            <div class="col-md-6">
                <a asp-controller="Lessen" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 text-center p-4 border-0">
                        <i class="bi bi-calendar-event text-primary mb-2" style="font-size:2.5rem;"></i>
                        <h5 class="fw-bold">@L["Lessons"]</h5>
                    </div>
                </a>
            </div>
            <div class="col-md-6">
                <a asp-controller="Inschrijvingen" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 text-center p-4 border-0">
                        <i class="bi bi-clipboard-check text-success mb-2" style="font-size:2.5rem;"></i>
                        <h5 class="fw-bold">@L["MyEnrollments"]</h5>
                    </div>
                </a>
            </div>
        }
    </div>
}
