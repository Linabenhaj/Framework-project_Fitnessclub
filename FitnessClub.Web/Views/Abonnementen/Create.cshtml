@using Microsoft.AspNetCore.Mvc.Localization
@using FitnessClub.Web.Resources
@inject IHtmlLocalizer<SharedResource> L
@model FitnessClub.Models.Models.Abonnement

@{ ViewData["Title"] = L["Add"].Value; }

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="bi bi-plus-circle"></i> @L["Add"] @L["Subscriptions"]</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Naam" class="form-label fw-bold">@L["Name"]</label>
                        <input asp-for="Naam" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Type" class="form-label fw-bold">Type</label>
                        <select asp-for="Type" class="form-select">
                            <option value="">—</option>
                            <option value="Basic">Basic</option>
                            <option value="Medium">Medium</option>
                            <option value="Pro">Pro</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Beschrijving" class="form-label fw-bold">@L["Description"]</label>
                        <textarea asp-for="Beschrijving" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Prijs" class="form-label fw-bold">@L["Price"] (€)</label>
                            <input asp-for="Prijs" class="form-control" type="number" step="0.01" min="0" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DuurInMaanden" class="form-label fw-bold">@L["EndTime"]</label>
                            <input asp-for="DuurInMaanden" class="form-control" type="number" min="1" max="36" />
                        </div>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="IsActief" class="form-check-input" />
                        <label asp-for="IsActief" class="form-check-label">@L["Available"]</label>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> @L["Back"]
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> @L["Add"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
