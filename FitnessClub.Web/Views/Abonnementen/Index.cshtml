@using Microsoft.AspNetCore.Mvc.Localization
@using FitnessClub.Web.Resources
@inject IHtmlLocalizer<SharedResource> L
@model FitnessClub.Web.Models.PaginatedList<FitnessClub.Models.Models.Abonnement>

@{
    ViewData["Title"] = L["Subscriptions"].Value;
}

<h1 class="mb-4"><i class="bi bi-credit-card"></i> @L["Subscriptions"]</h1>

<div class="row mb-3">
    <div class="col-md-6">
        <form method="get" class="input-group">
            <input type="text" class="form-control" name="searchString"
                   value="@ViewData["CurrentFilter"]" placeholder="@L["Search"]..." />
            <button class="btn btn-primary" type="submit">
                <i class="bi bi-search"></i> @L["Search"]
            </button>
        </form>
    </div>
    <div class="col-md-6 text-end">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> @L["Add"]
            </a>
        }
    </div>
</div>

@if (Model != null && Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>@L["Name"]</th>
                    <th>@L["Price"]</th>
                    <th>@L["Description"]</th>
                    <th>@L["Status"]</th>
                    <th class="text-end">@L["Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td><strong>@a.Naam</strong> <span class="badge bg-info">@a.Type</span></td>
                        <td>€ @a.Prijs.ToString("F2") / @a.DuurInMaanden mnd</td>
                        <td>@a.Beschrijving</td>
                        <td>
                            <span class="badge @(a.IsActief ? "bg-success" : "bg-secondary")">
                                @(a.IsActief ? L["Available"] : "—")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-info btn-sm">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-warning btn-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@a.Id" class="btn btn-danger btn-sm">
                                    <i class="bi bi-trash"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav>
        <ul class="pagination justify-content-center">
            @if (Model.HasPreviousPage)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index"
                       asp-route-pageNumber="@(Model.PageIndex - 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]">@L["Back"]</a>
                </li>
            }
            <li class="page-item active"><span class="page-link">@Model.PageIndex / @Model.TotalPages</span></li>
            @if (Model.HasNextPage)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index"
                       asp-route-pageNumber="@(Model.PageIndex + 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]">→</a>
                </li>
            }
        </ul>
    </nav>
}
else
{
    <div class="alert alert-info"><i class="bi bi-info-circle"></i> 0</div>
}
