@using Microsoft.AspNetCore.Mvc.Localization
@using FitnessClub.Web.Translations
@inject IHtmlLocalizer<SharedResource> L
@model FitnessClub.Models.Models.Abonnement

@{ ViewData["Title"] = L["Details"].Value; }

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="bi bi-credit-card"></i> @Model.Naam</h4>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Type</dt>
                    <dd class="col-sm-8"><span class="badge bg-info">@Model.Type</span></dd>

                    <dt class="col-sm-4">@L["Price"]</dt>
                    <dd class="col-sm-8"><strong class="text-success">€ @Model.Prijs.ToString("F2")</strong></dd>

                    <dt class="col-sm-4">@L["Description"]</dt>
                    <dd class="col-sm-8">@Model.Beschrijving</dd>

                    <dt class="col-sm-4">@L["Status"]</dt>
                    <dd class="col-sm-8">
                        <span class="badge @(Model.IsActief ? "bg-success" : "bg-secondary")">
                            @(Model.IsActief ? L["Available"] : "—")
                        </span>
                    </dd>
                </dl>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> @L["Back"]
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <div>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">@L["Edit"]</a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">@L["Delete"]</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
