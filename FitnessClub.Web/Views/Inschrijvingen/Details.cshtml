@using Microsoft.AspNetCore.Mvc.Localization
@using FitnessClub.Web.Resources
@inject IHtmlLocalizer<SharedResource> L
@model FitnessClub.Models.Models.Inschrijving

@{ ViewData["Title"] = L["Details"].Value; }

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="bi bi-clipboard-check"></i> @L["Details"]</h4>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">@L["Lessons"]</dt>
                    <dd class="col-sm-8">@Model.Les?.Naam</dd>

                    <dt class="col-sm-4">@L["Trainer"]</dt>
                    <dd class="col-sm-8">@Model.Les?.Trainer</dd>

                    <dt class="col-sm-4">@L["Location"]</dt>
                    <dd class="col-sm-8">@Model.Les?.Locatie</dd>

                    <dt class="col-sm-4">@L["StartTime"]</dt>
                    <dd class="col-sm-8">@Model.Les?.StartTijd.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-4">@L["Users"]</dt>
                    <dd class="col-sm-8">@Model.Gebruiker?.Voornaam @Model.Gebruiker?.Achternaam</dd>

                    <dt class="col-sm-4">@L["Status"]</dt>
                    <dd class="col-sm-8"><span class="badge bg-success">@Model.Status</span></dd>
                </dl>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> @L["Back"]
                </a>
                <form asp-action="Uitschrijf" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-x-circle"></i> @L["Unenroll"]
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
