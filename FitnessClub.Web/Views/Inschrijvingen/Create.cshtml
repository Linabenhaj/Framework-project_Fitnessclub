@model FitnessClub.Models.Models.Inschrijving

@{
    ViewData["Title"] = "Nieuwe inschrijving";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="bi bi-clipboard-plus"></i> Nieuwe inschrijving</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="LesId" class="form-label fw-bold">Les</label>
                        <select asp-for="LesId" asp-items="ViewBag.LessenList" class="form-select">
                            <option value="">-- Kies een les --</option>
                        </select>
                        <span asp-validation-for="LesId" class="text-danger"></span>
                    </div>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="mb-3">
                            <label asp-for="GebruikerId" class="form-label fw-bold">Gebruiker</label>
                            <select asp-for="GebruikerId" asp-items="ViewBag.GebruikersList" class="form-select">
                                <option value="">-- Kies een gebruiker --</option>
                            </select>
                            <span asp-validation-for="GebruikerId" class="text-danger"></span>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" asp-for="GebruikerId" />
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> Je schrijft jezelf in voor deze les.
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="Opmerkingen" class="form-label fw-bold">Opmerkingen (optioneel)</label>
                        <textarea asp-for="Opmerkingen" class="form-control" rows="2"
                                  placeholder="Eventuele bijzonderheden..."></textarea>
                    </div>

                    <input type="hidden" asp-for="InschrijfDatum" value="@DateTime.UtcNow" />
                    <input type="hidden" asp-for="Status" value="Actief" />

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Terug
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Inschrijven
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
