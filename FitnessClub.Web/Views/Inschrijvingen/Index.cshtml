@using Microsoft.AspNetCore.Mvc.Localization
@using FitnessClub.Web.Resources
@inject IHtmlLocalizer<SharedResource> L
@model FitnessClub.Web.Models.PaginatedList<FitnessClub.Models.Models.Inschrijving>

@{
    ViewData["Title"] = (User.IsInRole("Admin") ? L["Enrollments"] : L["MyEnrollments"]).Value;
}

<h1 class="mb-4"><i class="bi bi-clipboard-check"></i> @ViewData["Title"]</h1>

@if (User.IsInRole("Admin"))
{
    var lessenMetTrainer = ViewBag.LessenMetTrainer as List<FitnessClub.Models.Models.Les>;
    if (lessenMetTrainer != null && lessenMetTrainer.Any())
    {
        <div class="card mb-4">
            <div class="card-header bg-warning">
                <h5 class="mb-0"><i class="bi bi-person-check"></i> Aangegeven trainers</h5>
            </div>
            <div class="card-body">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr><th>Les</th><th>@L["StartTime"]</th><th>@L["Trainer"]</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var l in lessenMetTrainer)
                        {
                            <tr>
                                <td><strong>@l.Naam</strong></td>
                                <td>@l.StartTijd.ToString("dd/MM/yyyy HH:mm")</td>
                                <td><span class="badge bg-warning text-dark">@l.Trainer</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

<div id="loadingInschrijvingen" class="text-center mb-3" style="display:none;">
    <div class="spinner-border text-primary" role="status"></div>
</div>

@* Declaratieve AJAX-form via data-ajax-* attributen (Unobtrusive Ajax) *@
<form id="filterInschrijvingenForm" class="mb-3"
      data-ajax="true"
      data-ajax-method="GET"
      data-ajax-url="@Url.Action("LoadInschrijvingenPartial", "Inschrijvingen")"
      data-ajax-mode="replace"
      data-ajax-update="#inschrijvingenContainer"
      data-ajax-loading="#loadingInschrijvingen">

    <div class="row g-2">
        <div class="col-md-6">
            <input type="text" id="searchInputI" name="searchString" class="form-control"
                   value="@ViewData["CurrentFilter"]" placeholder="@L["Search"]..." />
        </div>
        <div class="col-md-4">
            <select name="sortOrder" class="form-select">
                <option value="">@L["Lessons"] A-Z</option>
                <option value="les_desc">@L["Lessons"] Z-A</option>
                <option value="datum">@L["StartTime"] (oudste eerst)</option>
                <option value="datum_desc">@L["StartTime"] (nieuwste eerst)</option>
                <option value="status">@L["Status"]</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-search"></i> @L["Search"]
            </button>
        </div>
    </div>
</form>

<div id="inschrijvingenContainer">
    @await Html.PartialAsync("_inschrijvingentable", Model)
</div>

@section Scripts {
    <script>
        // Auto-submit met debounce — live zoeken zonder pagina-reload
        $(function () {
            let t;
            $('#searchInputI, #filterInschrijvingenForm select').on('input change', function () {
                clearTimeout(t);
                t = setTimeout(function () {
                    $('#filterInschrijvingenForm').submit();
                }, 400);
            });
        });
    </script>
}
