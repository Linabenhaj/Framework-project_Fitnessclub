<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FitnessClub.MAUI.Views.ProfielPage"
             Title="Mijn Profiel"
             BackgroundColor="#F4F6F8">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <!-- Header -->
            <Label Text="👤 Mijn Profiel"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#1B5E20"/>

            <Label Text="{Binding Rol, StringFormat='Rol: {0}'}"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="Gray"/>

            <!-- Profiel gegevens -->
            <Frame CornerRadius="12" Padding="20" BackgroundColor="White" HasShadow="True">
                <VerticalStackLayout Spacing="14">

                    <Label Text="Persoonlijke gegevens"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#757575"/>

                    <Grid ColumnDefinitions="120,*" RowSpacing="10">
                        <Label Grid.Row="0" Grid.Column="0" Text="Voornaam" FontAttributes="Bold"/>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding Voornaam}"/>
                    </Grid>

                    <Grid ColumnDefinitions="120,*">
                        <Label Grid.Column="0" Text="Achternaam" FontAttributes="Bold"/>
                        <Label Grid.Column="1" Text="{Binding Achternaam}"/>
                    </Grid>

                    <Grid ColumnDefinitions="120,*">
                        <Label Grid.Column="0" Text="E-mail" FontAttributes="Bold"/>
                        <Label Grid.Column="1" Text="{Binding Email}" LineBreakMode="WordWrap"/>
                    </Grid>

                    <Grid ColumnDefinitions="120,*">
                        <Label Grid.Column="0" Text="Telefoon" FontAttributes="Bold"/>
                        <Label Grid.Column="1" Text="{Binding Telefoon}"/>
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- Abonnement -->
            <Frame CornerRadius="12" Padding="20" BackgroundColor="White" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Abonnement"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#757575"/>
                    <Label Text="{Binding AbonnementNaam}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#1B5E20"/>
                    <Label Text="{Binding AbonnementPrijs}"
                           FontSize="14"
                           TextColor="Gray"/>
                    <Label Text="{Binding AantalInschrijvingen, StringFormat='Actieve inschrijvingen: {0}'}"
                           FontSize="13"
                           TextColor="Gray"
                           Margin="0,6,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Info-box: wijzigen via klantendienst (enkel voor leden, niet trainer) -->
            <Frame CornerRadius="12" Padding="20" BackgroundColor="#FFF3E0"
                   IsVisible="{Binding MagKlantendienstZien}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="ℹ️ Gegevens wijzigen?"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#E65100"/>
                    <Label Text="Om je abonnement of persoonlijke gegevens te wijzigen, kun je onze klantendienst contacteren via:"
                           FontSize="13"
                           TextColor="#5D4037"/>
                    <Label Text="{Binding ContactEmail, StringFormat='📧 {0}'}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#1B5E20"/>
                    <Label Text="{Binding ContactTelefoon, StringFormat='📞 {0}'}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#1B5E20"/>
                    <Label Text="Bereikbaar maandag tot vrijdag, 9u-18u"
                           FontSize="12"
                           FontAttributes="Italic"
                           TextColor="Gray"/>
                </VerticalStackLayout>
            </Frame>

            <Button Text="⬅️ Terug"
                    Clicked="OnBackClicked"
                    BackgroundColor="#9E9E9E"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="46"
                    Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
