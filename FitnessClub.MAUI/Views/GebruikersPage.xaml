<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FitnessClub.MAUI.ViewModels"
             xmlns:svc="clr-namespace:FitnessClub.MAUI.Services"
             x:DataType="vm:GebruikersViewModel"
             x:Class="FitnessClub.MAUI.Views.GebruikersPage"
             Title="Gebruikers"
             BackgroundColor="#F4F6F8">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Loading indicator -->
        <ActivityIndicator Grid.Row="0"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="#1B5E20"
                           HorizontalOptions="Center"
                           Margin="0,8" />

        <!-- Statische titel + telling -->
        <Border Grid.Row="1"
                BackgroundColor="White"
                Padding="16,12"
                StrokeThickness="0">
            <Label FontSize="15"
                   FontAttributes="Bold"
                   TextColor="#1B5E20">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Geregistreerde gebruikers " />
                        <Span Text="(" />
                        <Span Text="{Binding Gebruikers.Count}" />
                        <Span Text=")" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
        </Border>

        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Gebruikers}"
                            EmptyView="Geen gebruikers gevonden"
                            Margin="0,4">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="svc:GebruikerInfo">
                        <Border Margin="12,5"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10">
                            <Border.Shadow>
                                <Shadow Brush="#22000000" Offset="0,2" Radius="5" Opacity="0.1" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="6,*,Auto">
                                <BoxView Grid.Column="0"
                                         BackgroundColor="#1B5E20"
                                         HorizontalOptions="Fill"
                                         VerticalOptions="Fill" />
                                <VerticalStackLayout Grid.Column="1" Padding="12,10" Spacing="3">
                                    <Label FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#212121">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding Voornaam}" />
                                                <Span Text=" " />
                                                <Span Text="{Binding Achternaam}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                    <Label Text="{Binding Email}"
                                           FontSize="12"
                                           TextColor="#616161" />
                                    <Label Text="{Binding Rol, StringFormat='Rol: {0}'}"
                                           FontSize="11"
                                           TextColor="#9E9E9E" />
                                </VerticalStackLayout>

                                <!-- Verwijder-knop — enkel zichtbaar voor Lid (NIET voor Admin of Trainer) -->
                                <Button Grid.Column="2"
                                        Text="🗑"
                                        BackgroundColor="#D32F2F"
                                        TextColor="White"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        CornerRadius="8"
                                        WidthRequest="44"
                                        HeightRequest="40"
                                        Margin="0,12,12,0"
                                        VerticalOptions="Start"
                                        IsVisible="{Binding IsLid}"
                                        Clicked="OnVerwijderClicked"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
