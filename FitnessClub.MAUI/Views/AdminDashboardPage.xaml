<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FitnessClub.MAUI.Views.AdminDashboardPage"
             Title="Beheer"
             BackgroundColor="#F4F6F8">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header banner -->
            <Grid BackgroundColor="#1B5E20" Padding="20,24,20,20">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding AdminNaam, StringFormat='Hallo, {0}'}"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Beheerdersportaal"
                           FontSize="13"
                           TextColor="#C8E6C9" />
                </VerticalStackLayout>
            </Grid>

            <!-- Stats-kaders verwijderd op vraag van gebruiker : vermeden caching-issues -->


            <!-- Acties -->
            <VerticalStackLayout Margin="16,20" Spacing="12">

                <Label Text="Acties"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#757575" />

                <Button Text="Bekijk alle lessen"
                        Command="{Binding BeheerLessenCommand}"
                        BackgroundColor="#1B5E20"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="50"
                        FontAttributes="Bold" />

                <Button Text="Nieuwe les aanmaken"
                        Command="{Binding NieuweLesCommand}"
                        BackgroundColor="#FF8F00"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="50"
                        FontAttributes="Bold" />

                <Button Text="Bekijk inschrijvingen"
                        Command="{Binding BeheerInschrijvingenCommand}"
                        BackgroundColor="#37474F"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="50"
                        FontAttributes="Bold" />

                <Button Text="Bekijk gebruikers"
                        Command="{Binding BekijkGebruikersCommand}"
                        BackgroundColor="#455A64"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="50"
                        FontAttributes="Bold" />

                <Button Text="Afmelden"
                        Command="{Binding LogoutCommand}"
                        BackgroundColor="#D32F2F"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="46"
                        Margin="0,10,0,0" />

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
