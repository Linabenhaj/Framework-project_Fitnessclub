<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FitnessClub.MAUI.ViewModels"
             xmlns:models="clr-namespace:FitnessClub.Models.Models;assembly=FitnessClub.Models"
             x:DataType="vm:InschrijvingenViewModel"
             x:Class="FitnessClub.MAUI.Views.InschrijvingenPage"
             Title="{Binding Title}"
             BackgroundColor="#F4F6F8">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Lading indicator -->
        <ActivityIndicator Grid.Row="0"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="#1B5E20"
                           HorizontalOptions="Center"
                           Margin="0,8" />

        <!--  Titel banner -->
        <Border Grid.Row="1"
                BackgroundColor="White"
                Padding="16,12"
                StrokeThickness="0">
            <Label Text="{Binding HeaderTitel}"
                   FontSize="15"
                   FontAttributes="Bold"
                   TextColor="#1B5E20"
                   HorizontalOptions="Start" />
        </Border>

        <!-- Lijst -->
        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding MijnInschrijvingen}"
                            EmptyView="Geen inschrijvingen gevonden"
                            Margin="0,4">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:LocalInschrijving">
                        <Border Margin="12,5"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10">
                            <Border.Shadow>
                                <Shadow Brush="#22000000" Offset="0,2" Radius="5" Opacity="0.1" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="6,*">
                                <BoxView Grid.Column="0"
                                         BackgroundColor="#2E7D32"
                                         HorizontalOptions="Fill"
                                         VerticalOptions="Fill" />
                                <VerticalStackLayout Grid.Column="1" Padding="12,10" Spacing="3">
                                    <Label Text="{Binding Les.Naam}"
                                           FontSize="15" FontAttributes="Bold" TextColor="#212121" />
                                    <Label Text="{Binding GebruikerNaam, StringFormat='Lid: {0}'}"
                                           FontSize="12" TextColor="#1B5E20" FontAttributes="Bold"
                                           IsVisible="{Binding GebruikerNaam, Converter={x:Static vm:StringNotEmptyConverter.Instance}}" />
                                    <Label Text="{Binding Les.StartTijd, StringFormat='Datum: {0:dd/MM/yyyy · HH:mm}'}"
                                           FontSize="12" TextColor="#616161" />
                                    <Label Text="{Binding Status, StringFormat='Status: {0}'}"
                                           FontSize="11" TextColor="#388E3C" FontAttributes="Bold" />
                                    <Label Text="{Binding InschrijfDatum, StringFormat='Ingeschreven op {0:dd/MM/yyyy}'}"
                                           FontSize="11" TextColor="#9E9E9E" />

                                    <!-- Uitschrijven knop -->
                                    <Button Text="Uitschrijven"
                                            BackgroundColor="#D32F2F"
                                            TextColor="White"
                                            FontSize="12"
                                            CornerRadius="8"
                                            Padding="10,6"
                                            HorizontalOptions="End"
                                            Clicked="OnUitschrijvenClicked"
                                            CommandParameter="{Binding .}"
                                            Margin="0,4,0,0" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
