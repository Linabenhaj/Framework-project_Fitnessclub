<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FitnessClub.MAUI.Views.LoginPage"
             Title=""
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F4F6F8">

    <Grid RowDefinitions="2*,3*">

        <!-- Bovenste helft: logo/branding -->
        <Grid Grid.Row="0" BackgroundColor="#1B5E20">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                <Label Text="FC"
                       FontSize="56"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center" />
                <Label Text="FitnessClub"
                       FontSize="18"
                       TextColor="#C8E6C9"
                       HorizontalOptions="Center" />
                <Label Text="Jouw gezondheid, onze passie"
                       FontSize="12"
                       TextColor="#81C784"
                       HorizontalOptions="Center"
                       Margin="0,4,0,0" />
            </VerticalStackLayout>
        </Grid>

        <!-- Onderste helft: formulier -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="28,24" Spacing="16">

                <!-- Foutmelding -->
                <Border x:Name="ErrorBorder"
                        BackgroundColor="#FFEBEE"
                        Stroke="#EF9A9A"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="12,10"
                        IsVisible="False">
                    <Label x:Name="ErrorLabel"
                           TextColor="#C62828"
                           FontSize="13" />
                </Border>

                <!-- E-mail -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="E-mailadres"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#424242" />
                    <Border BackgroundColor="White"
                            Stroke="#E0E0E0"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            Padding="12,0">
                        <Entry x:Name="EmailEntry"
                               Placeholder="naam@voorbeeld.be"
                               PlaceholderColor="#BDBDBD"
                               Keyboard="Email"
                               BackgroundColor="Transparent"
                               FontSize="14"
                               HeightRequest="46" />
                    </Border>
                </VerticalStackLayout>

                <!-- Wachtwoord -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Wachtwoord"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#424242" />
                    <Border BackgroundColor="White"
                            Stroke="#E0E0E0"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            Padding="12,0">
                        <Entry x:Name="PasswordEntry"
                               Placeholder="••••••••"
                               PlaceholderColor="#BDBDBD"
                               IsPassword="True"
                               BackgroundColor="Transparent"
                               FontSize="14"
                               HeightRequest="46" />
                    </Border>
                </VerticalStackLayout>

                <!-- Activiteitsindicator -->
                <ActivityIndicator x:Name="BusyIndicator"
                                   IsRunning="False"
                                   IsVisible="False"
                                   Color="#1B5E20"
                                   HorizontalOptions="Center" />

                <!-- Inloggen knop -->
                <Button x:Name="LoginButton"
                        Text="Aanmelden"
                        Clicked="OnLoginClicked"
                        BackgroundColor="#1B5E20"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="15"
                        CornerRadius="10"
                        HeightRequest="50"
                        Margin="0,8,0,0" />

                <!-- Registreren link -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                    <Label Text="Nog geen account?"
                           FontSize="13"
                           TextColor="#757575" />
                    <Label Text="Registreer hier"
                           FontSize="13"
                           TextColor="#1B5E20"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRegisterTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <!-- Snelknoppen voor testen (zichtbaarheid via code-behind) -->
                <StackLayout x:Name="DevPanel" IsVisible="False" Spacing="8">
                    <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" />
                    <Label Text="Testaccounts"
                           FontSize="11"
                           TextColor="#9E9E9E"
                           HorizontalOptions="Center" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="Admin"
                                Clicked="OnAutofillAdminClicked"
                                BackgroundColor="#37474F"
                                TextColor="White"
                                FontSize="12"
                                CornerRadius="8"
                                HeightRequest="40" />
                        <Button Grid.Column="1"
                                Text="Lid"
                                Clicked="OnAutofillLidClicked"
                                BackgroundColor="#546E7A"
                                TextColor="White"
                                FontSize="12"
                                CornerRadius="8"
                                HeightRequest="40" />
                    </Grid>
                </StackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
