<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FitnessClub.MAUI.Views.HomePage"
             Title="FitnessClub">

    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout Spacing="40" Padding="30"
                                 VerticalOptions="Center">

                <!-- App Logo/Title -->
                <Label Text="🏋️ FitnessClub"
                       FontSize="40"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#4CAF50"/>

                <!-- Welcome Message -->
                <Label Text="Welkom op FitnessClub"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#333333"/>

                <!-- Main Action Buttons -->
                <VerticalStackLayout Spacing="20">

                    <!-- Login Button -->
                    <Button Text="🔐 Inloggen"
                            Command="{Binding NavigateToLoginCommand}"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="60"
                            FontSize="16"
                            FontAttributes="Bold"/>

                    <!-- Registratie Button -->
                    <Button Text="📝 Registreren"
                            Command="{Binding NavigateToRegisterCommand}"
                            BackgroundColor="#2196F3"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="60"
                            FontSize="16"
                            FontAttributes="Bold"/>

                </VerticalStackLayout>

                <!-- Demo Info -->
                <Frame CornerRadius="10" Padding="15"
                       BackgroundColor="#FFF3E0">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="💡 Demo Accounts"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                        <Label Text="Admin: admin@fitnessclub.be / Admin123!"
                               FontSize="12"/>
                        <Label Text="Trainer: trainer@fitnessclub.be / Trainer123!"
                               FontSize="12"/>
                        <Label Text="Lid: user@fitnessclub.be / User123!"
                               FontSize="12"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>

</ContentPage>
