<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:FitnessClub.MAUI.Views"
       x:Class="FitnessClub.MAUI.AppShell"
       FlyoutBehavior="Flyout"
       FlyoutWidth="260"
       FlyoutBackgroundColor="#121212"
       Shell.TabBarIsVisible="False"
       Shell.ForegroundColor="White"
       Shell.TitleColor="White"
       Shell.NavBarHasShadow="False">

    <Shell.Resources>
        <!-- style voor flyout items zwarte achtergrond witte tekst -->
        <Style TargetType="FlyoutItem">
            <Setter Property="Shell.BackgroundColor" Value="#121212" />
            <Setter Property="Shell.ForegroundColor" Value="White" />
        </Style>

        <!-- style voor Shell zelf groene navigatiebalk -->
        <Style TargetType="Shell" ApplyToDerivedTypes="True">
            <Setter Property="Shell.BackgroundColor" Value="#1B5E20" />
        </Style>
    </Shell.Resources>

    <!-- Flyout item template forceert witte tekst op donkere achtergrond -->
    <Shell.ItemTemplate>
        <DataTemplate x:DataType="BaseShellItem">
            <Grid BackgroundColor="#121212" HeightRequest="50">
                <Label Text="{Binding Title}"
                       TextColor="White"
                       FontSize="15"
                       VerticalOptions="Center"
                       Margin="20,0" />
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <!-- Afmelden krijgt een duidelijke rode accentkleur -->
    <Shell.MenuItemTemplate>
        <DataTemplate x:DataType="MenuItem">
            <Grid BackgroundColor="#1A1A1A" HeightRequest="55">
                <Label Text="{Binding Text}"
                       TextColor="#EF5350"
                       FontSize="15"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       Margin="20,0" />
            </Grid>
        </DataTemplate>
    </Shell.MenuItemTemplate>

    <!--  header -->
    <Shell.FlyoutHeader>
        <Grid BackgroundColor="#1B5E20" HeightRequest="110" Padding="16,0">
            <VerticalStackLayout VerticalOptions="Center" Spacing="4">
                <Label Text="FC"
                       FontSize="40"
                       FontAttributes="Bold"
                       TextColor="White" />
                <Label Text="FitnessClub"
                       FontSize="13"
                       TextColor="#C8E6C9" />
                <Label x:Name="UserNameLabel"
                       Text="Welkom"
                       FontSize="11"
                       TextColor="#A5D6A7" />
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <!-- Lessen (iedereen) -->
    <FlyoutItem x:Name="LessenItem"
                Title="Lessen"
                Route="LessenShell">
        <ShellContent ContentTemplate="{DataTemplate views:LessenPage}" />
    </FlyoutItem>

    <!-- Mijn inschrijvingen (iedereen) -->
    <FlyoutItem x:Name="InschrijvingenItem"
                Title="Inschrijvingen"
                Route="InschrijvingenShell">
        <ShellContent ContentTemplate="{DataTemplate views:InschrijvingenPage}" />
    </FlyoutItem>

    <!-- Admin dashboard (alleen admin) -->
    <FlyoutItem x:Name="AdminDashboardItem"
                Title="Beheer"
                Route="AdminShell"
                IsVisible="False">
        <ShellContent ContentTemplate="{DataTemplate views:AdminDashboardPage}" />
    </FlyoutItem>

    <!-- Gebruikerslijst (alleen admin) -->
    <FlyoutItem x:Name="GebruikersItem"
                Title="Gebruikers"
                Route="GebruikersShell"
                IsVisible="False">
        <ShellContent ContentTemplate="{DataTemplate views:GebruikersPage}" />
    </FlyoutItem>

    <!-- Profiel (iedereen) -->
    <FlyoutItem x:Name="ProfielItem"
                Title="Mijn profiel"
                Route="ProfielShell">
        <ShellContent ContentTemplate="{DataTemplate views:ProfielPage}" />
    </FlyoutItem>

    <!-- Afmelden -->
    <MenuItem Text="Afmelden"
              Clicked="OnLogoutClicked" />

</Shell>
